# ---------------------------------------------------------------
# Domain For Sale — Environment Variables
# Copy this file to .env for local dev (never commit .env)
# In production, set all of these as Cloudflare secret variables:
#   Cloudflare Dashboard → Pages → <project> → Settings → Variables
# ---------------------------------------------------------------

# Email address where offer notifications are delivered
OWNER_EMAIL=you@yourdomain.com

# Sender address for outbound emails (must be verified in SMTP2GO)
FROM_EMAIL=noreply@yourdomain.com

# SMTP2GO API key — https://app.smtp2go.com/settings/apikeys
SMTP2GO_API_KEY=api-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Cloudflare Turnstile SECRET key (server-side)
# Get from: https://dash.cloudflare.com → Turnstile → your widget
# The SITE key (public) goes in config/domains.json
TURNSTILE_SECRET=0x4AAAAAAA_replace_with_your_secret_key
